{
  "$schema": "https://raw.githubusercontent.com/nicegoodthings/nicegoodthings.github.io/refs/heads/main/tauri2.schema.json",
  "productName": "sgChat",
  "version": "1.0.0",
  "identifier": "com.sosiagaming.sgchat",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "sgChat",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.sosiagaming.com wss://*.sosiagaming.com https://api.giphy.com https://media*.giphy.com https://tenor.googleapis.com; img-src 'self' data: blob: https:; media-src 'self' blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "sgChat"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "languages": ["English"]
      }
    }
  }
}
