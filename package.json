{
  "name": "sgchat-desktop",
  "version": "1.0.0",
  "description": "sgChat Desktop Client — independent Electron app for sgChat servers",
  "main": "dist/main/index.cjs",
  "author": "DemonFiend",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:debug": "vite serve src/renderer --config vite.config.ts --mode development",
    "build:main": "node scripts/build-main.mjs",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --outfile=dist/preload/index.cjs --external:electron --format=cjs --sourcemap",
    "build:renderer": "vite build",
    "lint": "eslint src/renderer/",
    "build": "npm run lint && npm run build:main && npm run build:preload && npm run build:renderer",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@jitsi/rnnoise-wasm": "^0.2.1",
    "@mantine/core": "^8.3.15",
    "@mantine/hooks": "^8.3.15",
    "@mantine/modals": "^8.3.18",
    "@mantine/notifications": "^8.3.15",
    "@tabler/icons-react": "^3.38.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.19",
    "application-loopback": "^1.2.7",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.0",
    "framer-motion": "^12.34.4",
    "livekit-client": "^2.17.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "chokidar": "^4.0.3",
    "electron": "^39.8.5",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
